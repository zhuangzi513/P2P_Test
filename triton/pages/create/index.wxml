<view class="container">
  <view class="info-tip">
    当前关联ID: {{id}}
  </view>

  <view class="form-item">
    <view class="label">color</view>
    <input class="input" placeholder="color" bindinput="onColorInput" value="{{color}}" />
  </view>
  <view class="form-item">
    <view class="label">shape </view>
    <input class="input" placeholder="shape-X" bindinput="onSizeInput" value="{{size}}" />
    <input class="input" placeholder="shape-Y" bindinput="onSizeInput" value="{{size}}" />
    <input class="input" placeholder="shape-Z" bindinput="onSizeInput" value="{{size}}" />
  </view>
  <view class="form-item">
    <view class="label">price</view>
    <input class="input" type="digit" placeholder="price high" bindinput="onHighPriceInput" value="{{price}}" />
    <input class="input" type="digit" placeholder="price low" bindinput="onLowPriceInput" value="{{price}}" />
  </view>

  <view class="upload-section">
    <view class="section-title">pic multi</view>
    <view class="media-list">
      <view class="media-item" wx:for="{{imageList}}" wx:key="index">
        <image class="preview-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
        <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">×</view>
      </view>
      <view class="add-btn" wx:if="{{imageList.length < 9}}" bindtap="chooseImage">
        <text>+</text>
      </view>
    </view>
  </view>

  <view class="upload-section">
    <view class="section-title">video 20M</view>
    <view class="media-list">
      <view class="media-item" wx:for="{{videoList}}" wx:key="index">
        <video class="preview-video" src="{{item.tempFilePath}}" controls="{{false}}" poster="{{item.thumbTempFilePath}}" />
        <view class="delete-btn" bindtap="deleteVideo" data-index="{{index}}">×</view>
      </view>
      <view class="add-btn" wx:if="{{videoList.length < 3}}" bindtap="chooseVideo">
        <text>+</text>
      </view>
    </view>
  </view>

  <button class="submit-btn" type="primary" bindtap="submit" loading="{{submitting}}" disabled="{{submitting}}">提交</button>
</view>
