/* 页面整体 */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f7fa;
}

/* 顶部标题 */
.title {
  padding: 30rpx 32rpx;
  font-size: 44rpx;
  font-weight: bold;
  background-color: white;
  border-bottom: 1rpx solid #e9ecef;
  color: #2c3e50;
}

/* 可滚动区域 */
.scroll-area {
  flex: 1;
  padding: 20rpx 24rpx 40rpx;
}

/* 每个区块 */
.section {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 8rpx solid #3b82f6;
  color: #1e293b;
}

/* 表格样式 */
.table {
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.table-row {
  display: flex;
  border-bottom: 1rpx solid #e2e8f0;
}
.table-row:last-child {
  border-bottom: none;
}
.table-header {
  background-color: #f8fafc;
  font-weight: 600;
  color: #334155;
}
.table-cell {
  flex: 1;
  padding: 20rpx 16rpx;
  text-align: center;
  font-size: 28rpx;
  word-break: break-word;
}
.description {
  background: #f1f5f9;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #475569;
  line-height: 1.5;
}

/* 按钮（用于展开卡片） */
.show-card-btn {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  border-radius: 60rpx;
  padding: 24rpx 0;
  text-align: center;
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  margin: 16rpx 0;
  transition: all 0.2s;
}
.show-card-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 卡片列表：四列布局（可根据屏幕宽度自适应，移动端通常2列，但需求为4个card，可设为grid 2x2） */
.card-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}
.card:active {
  transform: scale(0.97);
}
.card-img {
  width: 100%;
  height: 180rpx;
  background-color: #eef2ff;
}
.card-text {
  display: block;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  text-align: center;
  color: #1f2937;
  font-weight: 500;
  border-top: 1rpx solid #f0f0f0;
}

/* 表单样式 */
.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}
.form-label {
  width: 160rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #334155;
}
.form-input {
  flex: 1;
  border: 1rpx solid #cbd5e1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: white;
}
.form-picker {
  flex: 1;
  border: 1rpx solid #cbd5e1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: white;
  color: #1e293b;
}

/* 双按钮区域 */
.button-group {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  margin-bottom: 20rpx;
}
.btn {
  flex: 1;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  border: none;
}
.btn-left {
  background-color: #10b981;
  color: white;
}
.btn-left::after {
  border: none;
}
.btn-right {
  background-color: #f59e0b;
  color: white;
}
.btn-right::after {
  border: none;
}

.bottom-placeholder {
  height: 40rpx;
}
