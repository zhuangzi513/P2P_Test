<view class="page">
  <view class="title">{{title}}</view>

  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="{{true}}">
    <view class="section">
      <view class="section-title">{{goodsDetail.basicInfo.name}}</view>
      <view class="table">
        <view class="table-row table-header">
          <view class="table-cell">X</view>
          <view class="table-cell">Y</view>
          <view class="table-cell">Z</view>
          <view class="table-cell">P</view>
        </view>
        <view class="table-row" wx:for="{{goodsDetail.basicInfo.shape}}" wx:key="index">
          <view class="table-cell">{{goodsDetail.basicInfo.shape.sizeX}}</view>
          <view class="table-cell">{{goodsDetail.basicInfo.shape.sizeY}}</view>
          <view class="table-cell">{{goodsDetail.basicInfo.shape.sizeZ}}</view>
          <view class="table-cell">{{goodsDetail.basicInfo.originalPrice}}</view>
        </view>
      </view>

      <view class="description">
        <text>{{{{ goodsDetail.basicInfo.characteristic }}}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">judge by expert</view>
      <view wx:if="{{!showCards}}" class="show-card-btn" bindtap="onShowCards">
        <text>call expert</text>
      </view>
      <view wx:else class="card-list">
        <view class="card" wx:for="{{cards}}" wx:key="index">
          <image class="card-img" src="{{item.image}}" mode="aspectFill"></image>
          <text class="card-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">I want it</view>
      <view class="form">
        <view class="form-item">
          <view class="form-label">offer</view>
          <input class="form-input" type="digit" placeholder="money" value="{{offerPrice}}" bindinput="onOfferPriceInput" />
        </view>
        <view class="form-item">
          <view class="form-label">paymentmethods</view>
          <picker mode="selector" range="{{paymentMethods}}" value="{{paymentIndex}}" bindchange="onPaymentChange">
            <view class="form-picker">{{paymentMethods[paymentIndex]}}</view>
          </picker>
        </view>
        <view class="form-item">
          <view class="form-label">enjoymentmethods</view>
          <picker mode="selector" range="{{enjoyMethods}}" value="{{enjoymentIndex}}" bindchange="onEnjoymentChange">
            <view class="form-picker">{{enjoymentMethods[enjoymentIndex]}}</view>
          </picker>
        </view>
      </view>
    </view>

    <view class="button-group">
      <button class="btn btn-left" bindtap="sendToA">发送给A</button>
      <button class="btn btn-right" bindtap="sendToB">发送给B</button>
    </view>

    <view class="bottom-placeholder"></view>
  </scroll-view>
</view>
