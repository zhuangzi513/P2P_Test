<view class="page-container">
  <view class="header-section">
    <view wx:if="{{ !apiUserInfoMap }}" class="login-container">
      <view class="login-tips">WELCOME</view>
      <view class="login-btn" bindtap="login">
        <text>LOGIN</text>
      </view>
    </view>
    
    <view wx:else class="user-info-container">
      <view class="user-main">
        <view class="user-detail">
          <view class="nickname-row">
            <text class="nickname">{{ apiUserInfoMap.base.nick ? apiUserInfoMap.base.nick : 'to reset nickname' }}</text>
          </view>
          <view class="user-id">ID: {{ apiUserInfoMap.base.id }}</view>
        </view>
      </view>
    </view>
    
  </view>

  <view class="other-section">
    <view class="section-title">ORDERS</view>
    <navigator wx:if="{{isShop}}" bindtap="createInputOrder" class="menu-item">
      <view class="menu-label">CREATE INPUT ORDER</view>
      <text class="arrow">INPUT</text>
    </navigator>
    <navigator wx:if="{{isShop}}" bindtap="createOutputOrder" class="menu-item">
      <view class="menu-label">CREATE OUTPUT ORDER</view>
      <text class="arrow">OUTPUT</text>
    </navigator>
    <navigator url="/pages/orders/input-order-list" class="menu-item">
      <view class="menu-label">INPUT ORDERS</view>
      <text class="arrow">INPUT ORDERS</text>
    </navigator>
    <navigator url="/pages/orders/output-order-list" class="menu-item">
      <view class="menu-label">OUTPUT ORDERS</view>
      <text class="arrow">OUTPUT ORDERS</text>
    </navigator>
    <navigator url="/pages/my/address" class="menu-item">
      <view class="menu-label">MY ADDR</view>
      <text class="arrow">MY ADDR</text>
    </navigator>
  </view>
</view>
